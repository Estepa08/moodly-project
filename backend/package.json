{
  "name": "moodly-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/rate-limit": "^11.1.0",
    "@prisma/client": "^6.0.0",
    "bcrypt": "^5.1.0",
    "csv-stringify": "^6.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "pdfkit": "^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/bcrypt": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.6",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
